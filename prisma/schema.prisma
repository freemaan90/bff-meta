generator client {
  provider      = "prisma-client"
  output        = "../src/generated"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id            String  @id @default(uuid())
  name          String
  useSharedMeta Boolean @default(true)
  phoneNumberId String?
  accessToken   String?
  wabaId        String?

  chatbotEnabled Boolean @default(false)
  chatbotMode    String  @default("rules") // "rules" | "ai" | "hybrid"
  chatbotRules   Json?
  chatbotPrompt  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incomingMessages IncomingMessage[]
  messages         Message[]
  campaigns        Campaign[]
  apiKeys          ApiKey[]
  users            User[]
  subscription     Subscription?
  billingRecords   BillingRecord[]
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  email     String   @unique
  password  String
  role      UserRole @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  AGENT
}

model Subscription {
  id                 String             @id @default(uuid())
  tenantId           String             @unique
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  plan               SubscriptionPlan   @default(FREE_TRIAL)
  status             SubscriptionStatus @default(ACTIVE)
  trialEndsAt        DateTime
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  monthlyFee         Float              @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

enum SubscriptionPlan {
  FREE_TRIAL
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model MetaMessagePrice {
  id          String   @id @default(uuid())
  countryCode String
  category    String   // "marketing" | "utility" | "authentication"
  priceUsd    Float
  updatedAt   DateTime @updatedAt

  @@unique([countryCode, category])
}

model BillingRecord {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  messageId String   @unique
  metaCost  Float
  period    String   // "2026-03"
  createdAt DateTime @default(now())
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
}

model Campaign {
  id          String         @id @default(uuid())
  tenantId    String
  template    String
  language    String
  total       Int            @default(0)
  sentCount   Int            @default(0)
  failedCount Int            @default(0)
  status      CampaignStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  messages    Message[]
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
}

model Message {
  id         String    @id @default(uuid())
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  phone     String
  type      String        @default("text")
  messageId String?
  status    MessageStatus @default(QUEUED)
  error     String?
  variables Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}


enum CampaignStatus {
  PENDING
  RUNNING
  FINISHED
  FAILED
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model IncomingMessage {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  messageId String  @unique
  from      String
  type      String
  text      String?
  raw       Json

  createdAt DateTime @default(now())
}
