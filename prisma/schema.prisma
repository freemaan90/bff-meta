generator client {
  provider      = "prisma-client"
  output        = "../src/generated"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id            String  @id @default(uuid())
  name          String
  phoneNumberId String?
  accessToken   String?

  chatbotEnabled Boolean @default(false)
  chatbotMode    String  @default("rules") // "rules" | "ai"
  chatbotRules   Json? // [{ contains: "hola", reply: "Hola! ¿Cómo estás?" }]
  chatbotPrompt  String? // prompt base para IA

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incomingMessages IncomingMessage[]
  messages         Message[]
  campaigns        Campaign[]
  apiKeys          ApiKey[]
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
}

model Campaign {
  id          String         @id @default(uuid())
  tenantId    String
  template    String
  language    String
  total       Int            @default(0)
  sentCount   Int            @default(0)
  failedCount Int            @default(0)
  status      CampaignStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  messages    Message[]
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
}

model Message {
  id         String    @id @default(uuid())
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  phone     String
  messageId String?
  status    MessageStatus @default(QUEUED)
  error     String?
  variables Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}


enum CampaignStatus {
  PENDING
  RUNNING
  FINISHED
  FAILED
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model IncomingMessage {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  messageId String  @unique
  from      String
  type      String
  text      String?
  raw       Json

  createdAt DateTime @default(now())
}
